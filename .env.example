# Telegram Bot Configuration
BOT_TOKEN=
ADMIN_ID=
ADMIN_CHANNEL_ID=0

# Reward Settings
REWARD_PER_REFERRAL=5
WITHDRAW_AMOUNTS=15,25,50,100

# Database
DATABASE_PATH=/app/data/referral_bot.db

# Logging
LOG_LEVEL=INFO

# Anti-twink protection
ANTITWINK_ENABLED=true
NEW_ACCOUNT_ID_THRESHOLD=8000000000
TWINK_BLOCK_REFERRAL=false

# User checks
BLOCK_ARABIC=true
PHONE_GATE_ENABLED=true

# PiarFlow API
PIARFLOW_API_KEY=
PIARFLOW_ENABLED=false
PIARFLOW_MAX_SPONSORS=5

# Telegram Bot Configuration
BOT_TOKEN=
ADMIN_ID=
ADMIN_CHANNEL_ID=0

# Reward Settings
REWARD_PER_REFERRAL=2.6
WITHDRAW_AMOUNTS=15,25,50,100
DAILY_BONUS_AMOUNT=0.2
DAILY_STREAK_BONUS_DAYS=7
DAILY_STREAK_BONUS_AMOUNT=1
BOX_GAME_REWARD_AMOUNT=0.1
BOX_GAME_COOLDOWN_MINUTES=30

# Database
DATABASE_PATH=/app/data/referral_bot.db

# Logging
LOG_LEVEL=INFO

# Anti-twink protection
ANTITWINK_ENABLED=true
NEW_ACCOUNT_ID_THRESHOLD=8000000000
TWINK_BLOCK_REFERRAL=false

# User checks
BLOCK_ARABIC=true
PHONE_GATE_ENABLED=false

# PiarFlow API
PIARFLOW_API_KEY=
PIARFLOW_ENABLED=false
PIARFLOW_MAX_SPONSORS=10

# Owner channels are checked before all sponsor tasks.
# Optional URLs/names are useful for private channels if the bot cannot create an invite link.
OWNER_CHANNEL_IDS=5372378314,-1003535579194,-1002749675652
OWNER_CHANNEL_URLS=
OWNER_CHANNEL_NAMES=
